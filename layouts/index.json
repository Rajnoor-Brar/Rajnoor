[
{{ range $i, $p := site.RegularPages -}}
{{ if $i }},{{ end }}
{
  "title": {{ $p.Title | jsonify }},
  "url":   {{ $p.RelPermalink | jsonify }},
  "kind":  {{ $p.Section | jsonify }},
  "tags":  {{ ($p.Params.tags | default slice) | jsonify }},
  "desc":  {{ ($p.Params.description | default "") | jsonify }}
}
{{- end }}
]
